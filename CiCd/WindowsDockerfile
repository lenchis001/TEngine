# Use a lightweight Windows base image
FROM mcr.microsoft.com/windows/servercore:ltsc2022

# Set environment variables
ENV WINLIBS_DIR=C:\\winlibs

# Set working directory
WORKDIR C:\\workspace

# Download and extract winlibs
RUN powershell -Command \
    Invoke-WebRequest -Uri https://github.com/brechtsanders/winlibs_mingw/releases/download/15.1.0posix-12.0.0-ucrt-r1/winlibs-i686-posix-dwarf-gcc-15.1.0-mingw-w64ucrt-12.0.0-r1.7z -OutFile winlibs.7z; \
    Expand-Archive -Path winlibs.7z -DestinationPath C:\\; \
    Rename-Item -Path C:\\winlibs-i686-posix-dwarf-gcc-15.1.0-mingw-w64ucrt-12.0.0-r1 -NewName $env:WINLIBS_DIR; \
    Remove-Item winlibs.7z

# Add winlibs to PATH
ENV PATH="${WINLIBS_DIR}\\bin;${PATH}"

# Verify g++ installation
RUN g++ --version

# Copy project files
COPY . C:\\workspace

# Configure cmake project
RUN powershell -Command \
    cmake -S . -B build -G "MinGW Makefiles" -DCMAKE_C_COMPILER=gcc -DCMAKE_CXX_COMPILER=g++

# Build the project
RUN powershell -Command cmake --build build

# Default command
CMD ["cmd.exe"]